@page "/trades"
@rendermode InteractiveServer
@inject ITradeDashboardApiClient ApiClient

<PageTitle>Trades</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">Trades</h1>
        <p class="text-muted mb-0">Create, update, and close positions through the Minimal API.</p>
    </div>
    <button class="btn btn-outline-primary" @onclick="ToggleAddSection">
        <span class="bi @(_showAddSection ? "bi-dash-lg" : "bi-plus-lg") me-1"></span>
        @(_showAddSection ? "Hide form" : "Add new")
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger">@_errorMessage</div>
}

<div class="row g-4">
    @if (_showAddSection)
    {
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h5">@(_editingId.HasValue ? "Edit trade" : "Add trade")</h2>
                    <EditForm Model="_form" OnValidSubmit="SaveAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label" for="trade-stock">Stock name</label>
                            <InputText id="trade-stock" class="form-control" @bind-Value="_form.StockName" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="entry-price">Entry price</label>
                                <InputNumber id="entry-price" class="form-control" @bind-Value="_form.EntryPrice" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="current-price">Current price</label>
                                <InputNumber id="current-price" class="form-control" @bind-Value="_form.CurrentPrice" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="position-size">Position size</label>
                                <InputNumber id="position-size" class="form-control" @bind-Value="_form.PositionSize" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="trade-account">Account</label>
                                <InputSelect id="trade-account" class="form-select" @bind-Value="_form.AccountId">
                                    <option value="0">Select an account</option>
                                    @if (_accounts is not null)
                                    {
                                        @foreach (var account in _accounts)
                                        {
                                            <option value="@account.Id">@account.AccountName</option>
                                        }
                                    }
                                </InputSelect>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="open-date">Open date</label>
                                <InputDate id="open-date" class="form-control" @bind-Value="_form.OpenDate" />
                            </div>
                            <div class="col-md-6 mb-3 d-flex align-items-end">
                                <div class="form-check mb-2">
                                    <InputCheckbox id="is-closed" class="form-check-input" @bind-Value="_form.IsClosed" />
                                    <label class="form-check-label" for="is-closed">Trade is closed</label>
                                </div>
                            </div>
                        </div>

                        @if (_form.IsClosed)
                        {
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label" for="close-price">Close price</label>
                                    <InputNumber id="close-price" class="form-control" @bind-Value="_form.ClosePrice" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label" for="close-date">Close date</label>
                                    <InputDate id="close-date" class="form-control" @bind-Value="_form.CloseDate" />
                                </div>
                            </div>
                        }

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">@(_editingId.HasValue ? "Save changes" : "Create trade")</button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="ResetForm">Clear</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    }

    <div class="@(_showAddSection ? "col-lg-8" : "col-12")">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5">Current trades</h2>

                @if (_trades is null)
                {
                    <p>Loading trades...</p>
                }
                else
                {
                    <div class="row mb-3 g-2">
                        <div class="col-md-4">
                            <input type="text" class="form-control" placeholder="Search by stock or account..."
                                   @bind="_searchTerm" @bind:event="oninput" @onkeyup="OnFilterChanged" />
                        </div>
                        <div class="col-md-3">
                            <select class="form-select" @bind="_accountFilter" @bind:after="OnFilterChanged">
                                <option value="0">All accounts</option>
                                @if (_accounts is not null)
                                {
                                    @foreach (var account in _accounts)
                                    {
                                        <option value="@account.Id">@account.AccountName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select class="form-select" @bind="_statusFilter" @bind:after="OnFilterChanged">
                                <option value="">All statuses</option>
                                <option value="open">Open</option>
                                <option value="closed">Closed</option>
                            </select>
                        </div>
                        <div class="col-md-2 text-end">
                            <span class="text-muted small">@FilteredTrades.Count() of @_trades.Count</span>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>Stock</th>
                                    <th>Account</th>
                                    <th>Opened</th>
                                    <th>Status</th>
                                    <th>P/L</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var trade in PagedTrades)
                                {
                                    <tr>
                                        <td>@trade.StockName</td>
                                        <td>@trade.AccountName</td>
                                        <td>@trade.OpenDate</td>
                                        <td>@(trade.CloseDate.HasValue ? "Closed" : "Open")</td>
                                        <td class="@(trade.ProfitLoss >= 0 ? "text-success" : "text-danger")">@trade.ProfitLoss.ToString("C")</td>
                                        <td class="text-end">
                                            <button type="button" class="btn btn-sm btn-outline-primary me-2" @onclick="() => Edit(trade)">Edit</button>
                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(trade.Id)">Delete</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (TotalPages > 1)
                    {
                        <nav aria-label="Trade pagination">
                            <ul class="pagination justify-content-center mb-0">
                                <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(1)" disabled="@(_currentPage == 1)">First</button>
                                </li>
                                <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(_currentPage - 1)" disabled="@(_currentPage == 1)">Previous</button>
                                </li>
                                @for (int i = Math.Max(1, _currentPage - 2); i <= Math.Min(TotalPages, _currentPage + 2); i++)
                                {
                                    var pageNum = i;
                                    <li class="page-item @(pageNum == _currentPage ? "active" : "")">
                                        <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                                    </li>
                                }
                                <li class="page-item @(_currentPage == TotalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(_currentPage + 1)" disabled="@(_currentPage == TotalPages)">Next</button>
                                </li>
                                <li class="page-item @(_currentPage == TotalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(TotalPages)" disabled="@(_currentPage == TotalPages)">Last</button>
                                </li>
                            </ul>
                        </nav>
                    }
                }
            </div>
        </div>
    </div>
</div>

@code {
    private IReadOnlyList<TradeDto>? _trades;
    private IReadOnlyList<AccountDto>? _accounts;
    private TradeFormModel _form = new();
    private int? _editingId;
    private string? _errorMessage;
    private bool _showAddSection = true;

    // Search, filter, and paging
    private string _searchTerm = string.Empty;
    private int _accountFilter;
    private string _statusFilter = string.Empty;
    private int _currentPage = 1;
    private const int PageSize = 10;

    private IEnumerable<TradeDto> FilteredTrades => _trades?
        .Where(t => string.IsNullOrWhiteSpace(_searchTerm) ||
                    t.StockName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    t.AccountName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(t => _accountFilter == 0 || t.AccountId == _accountFilter)
        .Where(t => string.IsNullOrEmpty(_statusFilter) ||
                    (_statusFilter == "open" && !t.CloseDate.HasValue) ||
                    (_statusFilter == "closed" && t.CloseDate.HasValue))
        ?? [];

    private IEnumerable<TradeDto> PagedTrades => FilteredTrades
        .Skip((_currentPage - 1) * PageSize)
        .Take(PageSize);

    private int TotalPages => (int)Math.Ceiling(FilteredTrades.Count() / (double)PageSize);

    private void OnFilterChanged()
    {
        _currentPage = 1;
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages)
        {
            _currentPage = page;
        }
    }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _errorMessage = null;
        _currentPage = 1;

        try
        {
            _accounts = await ApiClient.GetAccountsAsync();
            _trades = await ApiClient.GetTradesAsync();
        }
        catch (ApiException exception)
        {
            _errorMessage = exception.Message;
        }
    }

    private async Task SaveAsync()
    {
        _errorMessage = null;

        try
        {
            if (_editingId.HasValue)
            {
                await ApiClient.UpdateTradeAsync(_editingId.Value, _form.ToRequest());
            }
            else
            {
                await ApiClient.CreateTradeAsync(_form.ToRequest());
            }

            ResetForm();
            await LoadAsync();
        }
        catch (ApiException exception)
        {
            _errorMessage = exception.Message;
        }
    }

    private void Edit(TradeDto trade)
    {
        _editingId = trade.Id;
        _form = TradeFormModel.FromDto(trade);
        _errorMessage = null;
        _showAddSection = true;
    }

    private async Task DeleteAsync(int id)
    {
        _errorMessage = null;

        try
        {
            await ApiClient.DeleteTradeAsync(id);
            await LoadAsync();
        }
        catch (ApiException exception)
        {
            _errorMessage = exception.Message;
        }
    }

    private void ResetForm()
    {
        _editingId = null;
        _form = new TradeFormModel();
        _errorMessage = null;
    }

    private void ToggleAddSection()
    {
        _showAddSection = !_showAddSection;
        if (!_showAddSection)
        {
            ResetForm();
        }
    }
}

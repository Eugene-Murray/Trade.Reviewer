@page "/accounts"
@rendermode InteractiveServer
@inject ITradeDashboardApiClient ApiClient

<PageTitle>Accounts</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">Accounts</h1>
        <p class="text-muted mb-0">Update account names and balances through the Minimal API.</p>
    </div>
    <button class="btn btn-outline-primary" @onclick="ToggleAddSection">
        <span class="bi @(_showAddSection ? "bi-dash-lg" : "bi-plus-lg") me-1"></span>
        @(_showAddSection ? "Hide form" : "Add new")
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger">@_errorMessage</div>
}

<div class="row g-4">
    @if (_showAddSection)
    {
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h5">@(_editingId.HasValue ? "Edit account" : "Add account")</h2>
                    <EditForm Model="_form" OnValidSubmit="SaveAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label" for="account-name">Account name</label>
                            <InputText id="account-name" class="form-control" @bind-Value="_form.AccountName" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="account-balance">Account balance</label>
                            <InputNumber id="account-balance" class="form-control" @bind-Value="_form.AccountBalance" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">@(_editingId.HasValue ? "Save changes" : "Create account")</button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="ResetForm">Clear</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    }

    <div class="@(_showAddSection ? "col-lg-8" : "col-12")">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5">Current accounts</h2>

                @if (_accounts is null)
                {
                    <p>Loading accounts...</p>
                }
                else
                {
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <input type="text" class="form-control" placeholder="Search by account name..."
                                   @bind="_searchTerm" @bind:event="oninput" @onkeyup="OnSearchChanged" />
                        </div>
                        <div class="col-md-6 text-end">
                            <span class="text-muted">@FilteredAccounts.Count() of @_accounts.Count accounts</span>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Balance</th>
                                    <th>Open trades</th>
                                    <th>Open exposure</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var account in PagedAccounts)
                                {
                                    <tr>
                                        <td>@account.AccountName</td>
                                        <td>@account.AccountBalance.ToString("C")</td>
                                        <td>@account.OpenTradeCount</td>
                                        <td>@account.OpenExposure.ToString("C")</td>
                                        <td class="text-end">
                                            <button type="button" class="btn btn-sm btn-outline-primary me-2" @onclick="() => Edit(account)">Edit</button>
                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(account.Id)">Delete</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (TotalPages > 1)
                    {
                        <nav aria-label="Account pagination">
                            <ul class="pagination justify-content-center mb-0">
                                <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(1)" disabled="@(_currentPage == 1)">First</button>
                                </li>
                                <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(_currentPage - 1)" disabled="@(_currentPage == 1)">Previous</button>
                                </li>
                                @for (int i = Math.Max(1, _currentPage - 2); i <= Math.Min(TotalPages, _currentPage + 2); i++)
                                {
                                    var pageNum = i;
                                    <li class="page-item @(pageNum == _currentPage ? "active" : "")">
                                        <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                                    </li>
                                }
                                <li class="page-item @(_currentPage == TotalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(_currentPage + 1)" disabled="@(_currentPage == TotalPages)">Next</button>
                                </li>
                                <li class="page-item @(_currentPage == TotalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(TotalPages)" disabled="@(_currentPage == TotalPages)">Last</button>
                                </li>
                            </ul>
                        </nav>
                    }
                }
            </div>
        </div>
    </div>
</div>

@code {
    private IReadOnlyList<AccountDto>? _accounts;
    private AccountFormModel _form = new();
    private int? _editingId;
    private string? _errorMessage;
    private bool _showAddSection = true;

    // Search and paging
    private string _searchTerm = string.Empty;
    private int _currentPage = 1;
    private const int PageSize = 10;

    private IEnumerable<AccountDto> FilteredAccounts => _accounts?
        .Where(a => string.IsNullOrWhiteSpace(_searchTerm) ||
                    a.AccountName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
        ?? [];

    private IEnumerable<AccountDto> PagedAccounts => FilteredAccounts
        .Skip((_currentPage - 1) * PageSize)
        .Take(PageSize);

    private int TotalPages => (int)Math.Ceiling(FilteredAccounts.Count() / (double)PageSize);

    private void OnSearchChanged()
    {
        _currentPage = 1;
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages)
        {
            _currentPage = page;
        }
    }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _errorMessage = null;
        _currentPage = 1;

        try
        {
            _accounts = await ApiClient.GetAccountsAsync();
        }
        catch (ApiException exception)
        {
            _errorMessage = exception.Message;
        }
    }

    private async Task SaveAsync()
    {
        _errorMessage = null;

        try
        {
            if (_editingId.HasValue)
            {
                await ApiClient.UpdateAccountAsync(_editingId.Value, _form.ToRequest());
            }
            else
            {
                await ApiClient.CreateAccountAsync(_form.ToRequest());
            }

            ResetForm();
            await LoadAsync();
        }
        catch (ApiException exception)
        {
            _errorMessage = exception.Message;
        }
    }

    private void Edit(AccountDto account)
    {
        _editingId = account.Id;
        _form = AccountFormModel.FromDto(account);
        _errorMessage = null;
        _showAddSection = true;
    }

    private async Task DeleteAsync(int id)
    {
        _errorMessage = null;

        try
        {
            await ApiClient.DeleteAccountAsync(id);
            await LoadAsync();
        }
        catch (ApiException exception)
        {
            _errorMessage = exception.Message;
        }
    }

    private void ResetForm()
    {
        _editingId = null;
        _form = new AccountFormModel();
        _errorMessage = null;
    }

    private void ToggleAddSection()
    {
        _showAddSection = !_showAddSection;
        if (!_showAddSection)
        {
            ResetForm();
        }
    }
}

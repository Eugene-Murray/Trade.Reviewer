@page "/watchlist"
@rendermode InteractiveWebAssembly
@inject ITradeDashboardApiClient ApiClient

<PageTitle>Watchlist</PageTitle>

<h1>Watchlist</h1>
<p>Maintain the seeded Nasdaq mega-cap watchlist over WebAssembly.</p>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger">@_errorMessage</div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5">@(_editingId.HasValue ? "Edit watchlist item" : "Add watchlist item")</h2>
                <EditForm Model="_form" OnValidSubmit="SaveAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label" for="stock-name">Stock name</label>
                        <InputText id="stock-name" class="form-control" @bind-Value="_form.StockName" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="watchlist-notes">Notes</label>
                        <InputTextArea id="watchlist-notes" class="form-control" @bind-Value="_form.Notes" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="date-added">Date added</label>
                        <InputDate id="date-added" class="form-control" @bind-Value="_form.DateAdded" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">@(_editingId.HasValue ? "Save changes" : "Create item")</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="ResetForm">Clear</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5">Current watchlist</h2>

                @if (_items is null)
                {
                    <p>Loading watchlist...</p>
                }
                else
                {
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <input type="text" class="form-control" placeholder="Search by stock name or notes..."
                                   @bind="_searchTerm" @bind:event="oninput" @onkeyup="OnSearchChanged" />
                        </div>
                        <div class="col-md-6 text-end">
                            <span class="text-muted">@FilteredItems.Count() of @_items.Count items</span>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>Stock</th>
                                    <th>Date added</th>
                                    <th>Signals</th>
                                    <th>Open trades</th>
                                    <th>Notes</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in PagedItems)
                                {
                                    <tr>
                                        <td>@item.StockName</td>
                                        <td>@item.DateAdded</td>
                                        <td>@item.SignalCount</td>
                                        <td>@item.OpenTradeCount</td>
                                        <td>@item.Notes</td>
                                        <td class="text-end">
                                            <button type="button" class="btn btn-sm btn-outline-primary me-2" @onclick="() => Edit(item)">Edit</button>
                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(item.Id)">Delete</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (TotalPages > 1)
                    {
                        <nav aria-label="Watchlist pagination">
                            <ul class="pagination justify-content-center mb-0">
                                <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(1)" disabled="@(_currentPage == 1)">First</button>
                                </li>
                                <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(_currentPage - 1)" disabled="@(_currentPage == 1)">Previous</button>
                                </li>
                                @for (int i = Math.Max(1, _currentPage - 2); i <= Math.Min(TotalPages, _currentPage + 2); i++)
                                {
                                    var pageNum = i;
                                    <li class="page-item @(pageNum == _currentPage ? "active" : "")">
                                        <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                                    </li>
                                }
                                <li class="page-item @(_currentPage == TotalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(_currentPage + 1)" disabled="@(_currentPage == TotalPages)">Next</button>
                                </li>
                                <li class="page-item @(_currentPage == TotalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(TotalPages)" disabled="@(_currentPage == TotalPages)">Last</button>
                                </li>
                            </ul>
                        </nav>
                    }
                }
            </div>
        </div>
    </div>
</div>

@code {
    private IReadOnlyList<WatchlistItemDto>? _items;
    private WatchlistFormModel _form = new();
    private int? _editingId;
    private string? _errorMessage;

    // Search and paging
    private string _searchTerm = string.Empty;
    private int _currentPage = 1;
    private const int PageSize = 10;

    private IEnumerable<WatchlistItemDto> FilteredItems => _items?
        .Where(i => string.IsNullOrWhiteSpace(_searchTerm) ||
                    i.StockName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    (i.Notes?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        ?? [];

    private IEnumerable<WatchlistItemDto> PagedItems => FilteredItems
        .Skip((_currentPage - 1) * PageSize)
        .Take(PageSize);

    private int TotalPages => (int)Math.Ceiling(FilteredItems.Count() / (double)PageSize);

    private void OnSearchChanged()
    {
        _currentPage = 1;
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages)
        {
            _currentPage = page;
        }
    }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _errorMessage = null;
        _currentPage = 1;

        try
        {
            _items = await ApiClient.GetWatchlistAsync();
        }
        catch (ApiException exception)
        {
            _errorMessage = exception.Message;
        }
    }

    private async Task SaveAsync()
    {
        _errorMessage = null;

        try
        {
            if (_editingId.HasValue)
            {
                await ApiClient.UpdateWatchlistItemAsync(_editingId.Value, _form.ToRequest());
            }
            else
            {
                await ApiClient.CreateWatchlistItemAsync(_form.ToRequest());
            }

            ResetForm();
            await LoadAsync();
        }
        catch (ApiException exception)
        {
            _errorMessage = exception.Message;
        }
    }

    private void Edit(WatchlistItemDto item)
    {
        _editingId = item.Id;
        _form = WatchlistFormModel.FromDto(item);
        _errorMessage = null;
    }

    private async Task DeleteAsync(int id)
    {
        _errorMessage = null;

        try
        {
            await ApiClient.DeleteWatchlistItemAsync(id);
            await LoadAsync();
        }
        catch (ApiException exception)
        {
            _errorMessage = exception.Message;
        }
    }

    private void ResetForm()
    {
        _editingId = null;
        _form = new WatchlistFormModel();
        _errorMessage = null;
    }
}

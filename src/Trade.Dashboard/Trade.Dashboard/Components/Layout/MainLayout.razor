@inherits LayoutComponentBase

<input type="checkbox" id="sidebar-toggle" class="sidebar-toggle-checkbox" />
<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>
    <label for="sidebar-toggle" class="sidebar-toggle" title="Toggle sidebar">
        <span class="toggle-icon"></span>
    </label>

    <main>
        <div class="top-row px-4">
            <span class="text-muted">Trade.Reviewer | SSR + Interactive Server + WebAssembly</span>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@page "/"

<PageTitle>Home</PageTitle>

<h1>Trade reviewer dashboard</h1>

<p class="lead">
    Manage seeded Nasdaq mega-cap watchlist ideas, trade signals, open positions, and account balances through the
    Trade.Mcp.Api service.
</p>

<div class="row g-4">
    <div class="col-md-6 col-xl-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5">Accounts</h2>
                <p>Interactive Server page for updating balances and account names.</p>
                <a class="btn btn-primary" href="accounts">Open accounts</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5">Watchlist</h2>
                <p>Interactive WebAssembly page for the 50-stock Nasdaq mega-cap watchlist.</p>
                <a class="btn btn-primary" href="watchlist">Open watchlist</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5">Trade signals</h2>
                <p>Interactive WebAssembly page for long and short signal management.</p>
                <a class="btn btn-primary" href="trade-signals">Open signals</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5">Trades</h2>
                <p>Interactive Server page for open and closed trade CRUD operations.</p>
                <a class="btn btn-primary" href="trades">Open trades</a>
            </div>
        </div>
    </div>
</div>
